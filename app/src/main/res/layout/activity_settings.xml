<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- AppBar -->
        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#0066cc"
                app:title="@string/settings"
                app:titleTextColor="@android:color/white"
                app:navigationIcon="@drawable/ic_arrow_back" />

        </com.google.android.material.appbar.AppBarLayout>

        <!-- Scrollable content -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="12dp"
                android:paddingBottom="24dp">

                <!-- ═══════════════════════════════════ -->
                <!--  SECTION: CURRENCY                  -->
                <!-- ═══════════════════════════════════ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_currency"
                    android:textColor="#0066cc"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:paddingStart="4dp"
                    android:paddingBottom="6dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Auto-detect row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingBottom="16dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/auto_detect_currency"
                                    android:textSize="15sp"
                                    android:textColor="#212121" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/auto_detect_currency_sub"
                                    android:textSize="13sp"
                                    android:textColor="#757575"
                                    android:layout_marginTop="2dp" />

                            </LinearLayout>

                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/switch_auto_detect"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checked="true"
                                app:thumbTint="#0066cc"
                                app:trackTint="#80b3e6" />

                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#E0E0E0"
                            android:layout_marginBottom="16dp" />

                        <!-- Currency picker row -->
                        <LinearLayout
                            android:id="@+id/row_currency_picker"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:alpha="0.4">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/select_currency"
                                android:textSize="15sp"
                                android:textColor="#212121"
                                android:paddingBottom="8dp" />

                            <Spinner
                                android:id="@+id/spinner_currency"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:background="@drawable/spinner_border"
                                android:enabled="false"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp" />

                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ═══════════════════════════════════ -->
                <!--  SECTION: ESTIMATES                 -->
                <!-- ═══════════════════════════════════ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_estimates"
                    android:textColor="#0066cc"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:paddingStart="4dp"
                    android:paddingBottom="6dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Default VAT -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/default_vat"
                            android:textSize="15sp"
                            android:textColor="#212121" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/default_vat_sub"
                            android:textSize="13sp"
                            android:textColor="#757575"
                            android:layout_marginTop="2dp"
                            android:paddingBottom="8dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_vat"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/vat_hint"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                            app:boxStrokeColor="#0066cc">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_vat"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:maxLength="5"
                                android:text="20" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#E0E0E0"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="16dp" />

                        <!-- Default expiration days -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/default_expiration"
                            android:textSize="15sp"
                            android:textColor="#212121" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/default_expiration_sub"
                            android:textSize="13sp"
                            android:textColor="#757575"
                            android:layout_marginTop="2dp"
                            android:paddingBottom="8dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_expiration"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/expiration_hint"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                            app:boxStrokeColor="#0066cc">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_expiration_days"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:maxLength="3"
                                android:text="30" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#E0E0E0"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="16dp" />

                        <!-- Default due terms -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/default_due_terms"
                            android:textSize="15sp"
                            android:textColor="#212121" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/default_due_terms_sub"
                            android:textSize="13sp"
                            android:textColor="#757575"
                            android:layout_marginTop="2dp"
                            android:paddingBottom="8dp" />

                        <Spinner
                            android:id="@+id/spinner_due_terms"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/spinner_border"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ═══════════════════════════════════ -->
                <!--  SECTION: DISPLAY                   -->
                <!-- ═══════════════════════════════════ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_display"
                    android:textColor="#0066cc"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:paddingStart="4dp"
                    android:paddingBottom="6dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Date format -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/date_format"
                            android:textSize="15sp"
                            android:textColor="#212121"
                            android:paddingBottom="8dp" />

                        <Spinner
                            android:id="@+id/spinner_date_format"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/spinner_border"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ═══════════════════════════════════ -->
                <!--  SECTION: DATA                      -->
                <!-- ═══════════════════════════════════ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_data"
                    android:textColor="#0066cc"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:paddingStart="4dp"
                    android:paddingBottom="6dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Backup reminder -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/backup_reminder"
                                    android:textSize="15sp"
                                    android:textColor="#212121" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/backup_reminder_sub"
                                    android:textSize="13sp"
                                    android:textColor="#757575"
                                    android:layout_marginTop="2dp" />

                            </LinearLayout>

                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/switch_backup_reminder"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checked="true"
                                app:thumbTint="#0066cc"
                                app:trackTint="#80b3e6" />

                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Save button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save_settings"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="@string/save_settings"
                    android:textSize="15sp"
                    android:backgroundTint="#0066cc"
                    app:cornerRadius="12dp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- Drawer menu -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:menu="@menu/drawer_menu"
        app:headerLayout="@layout/nav_header"
        app:itemIconTint="@color/drawer_icon_color"
        android:background="@android:color/white" />

</androidx.drawerlayout.widget.DrawerLayout>
